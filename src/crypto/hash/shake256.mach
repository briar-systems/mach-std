        0xe4, 0xe1, 0xb9, 0xa4, 0x6c, 0xbe, 0x85, 0x47, 0x13, 0x67, 0x2f, 0x5c,
        0xaa, 0xae, 0x31, 0x4e, 0xd9, 0x08, 0x3d, 0xab
    };
    var i: usize = 0;
    for (i < 200) {
        if (d[i] != e[i]) { ret 1; }
        i = i + 1;
    }
    ret 0;
}
